{
  "name": "urban-map-remote",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/urban-map-remote/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-architects/native-federation-v4:build",
      "options": {
        "projectName": "urban-map-remote",
        "tsConfig": "apps/urban-map-remote/tsconfig.federation.json",
        "cacheExternalArtifacts": true,
        "entryPoints": [
          "apps/urban-map-remote/src/main.ts"
        ]
      },
      "configurations": {
        "production": {
          "target": "urban-map-remote:esbuild:production"
        },
        "development": {
          "target": "urban-map-remote:esbuild:development",
          "dev": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-architects/native-federation-v4:build",
      "options": {
        "projectName": "urban-map-remote",
        "tsConfig": "apps/urban-map-remote/tsconfig.federation.json",
        "target": "urban-map-remote:serve-original:development",
        "rebuildDelay": 500,
        "cacheExternalArtifacts": true,
        "dev": true,
        "devServer": true,
        "port": 4201,
        "entryPoints": [
          "apps/urban-map-remote/src/main.ts"
        ]
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "urban-map-remote:build",
        "staticFilePath": "dist/apps/urban-map-remote/browser",
        "spa": true
      }
    },
    "esbuild": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/urban-map-remote",
        "browser": "apps/urban-map-remote/src/main.ts",
        "tsConfig": "apps/urban-map-remote/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/urban-map-remote/public"
          }
        ],
        "styles": [
          "apps/urban-map-remote/src/styles.scss"
        ],
        "polyfills": [
          "es-module-shims"
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      }
    },
    "serve-original": {
      "continuous": true,
      "executor": "@nx/angular:dev-server",
      "defaultConfiguration": "development",
      "configurations": {
        "production": {
          "buildTarget": "urban-map-remote:esbuild:production"
        },
        "development": {
          "buildTarget": "urban-map-remote:esbuild:development"
        }
      },
      "options": {
        "port": 4201,
        "watch": true
      }
    }
  }
}
